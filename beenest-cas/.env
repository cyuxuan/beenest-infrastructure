# ---------- 认证能力开关 ----------
CAS_AUTHN_ACCEPT_ENABLED=false
CAS_AUTHN_ACCEPT_USERS=
CAS_FEATURE_THROTTLING_ENABLED=true
CAS_FEATURE_CONSENT_ENABLED=false
CAS_FEATURE_AUP_ENABLED=false
CAS_FEATURE_LDAP_AUTH_ENABLED=false
CAS_INTERRUPT_FORCE_EXECUTION=false
CAS_INTERRUPT_TRIGGER_MODE=AFTER_AUTHENTICATION

# 登录限流
CAS_AUTHN_THROTTLE_CORE_USERNAME_PARAMETER=username
CAS_AUTHN_THROTTLE_FAILURE_THRESHOLD=5
CAS_AUTHN_THROTTLE_FAILURE_RANGE_SECONDS=300
CAS_AUTHN_THROTTLE_FAILURE_WINDOW=PT10M
CAS_AUTHN_THROTTLE_JDBC_ENABLED=true

# 密码策略: 至少 12 位，包含大小写、数字、特殊字符。
CAS_PM_PASSWORD_POLICY_PATTERN='^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{12,128}$'

# 可选 LDAP，默认关闭。
CAS_LDAP_URL=
CAS_LDAP_TYPE=AUTHENTICATED
CAS_LDAP_BASE_DN=
CAS_LDAP_SEARCH_FILTER=uid={user}
CAS_LDAP_BIND_DN=
CAS_LDAP_BIND_CREDENTIAL=
CAS_LDAP_PRINCIPAL_ATTRIBUTE_ID=uid
CAS_LDAP_PRINCIPAL_ATTRIBUTE_LIST=cn,mail,uid
CAS_LDAP_ORDER=0

# ---------- Token ----------
ACCESS_TOKEN_TTL=604800
REFRESH_TOKEN_TTL=31536000
BEENEST_AUTO_GRANT_SERVICE_IDS=10001

# ---------- 小程序登录 ----------
WECHAT_APPID=wxb825c278b136da28
WECHAT_SECRET=c9f7a58d0db509d2b93893e512bc21bc
DOUYIN_APPID=
DOUYIN_SECRET=
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_AES_KEY=

# ---------- 短信 ----------
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=Beenest
SMS_TEMPLATE_CODE=

# ---------- 邮件 ----------
MAIL_HOST=smtp.beenest.club
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ACCOUNT_REGISTRATION_FROM=no-reply@beenest.club
ACCOUNT_REGISTRATION_SUBJECT="Beenest 账号注册激活"

# ---------- 日志 ----------
LOG_LEVEL_CAS=INFO
LOG_LEVEL_BEENEST=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_SPRING_WEB=INFO
