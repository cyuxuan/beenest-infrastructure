# ---------- Spring / Server ----------
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8081
SERVER_SSL_ENABLED=false
SERVER_FORWARD_HEADERS_STRATEGY=framework
JAVA_OPTS="-Xms512m -Xmx1024m -Dfile.encoding=UTF-8"

# CAS 对外访问地址。若前面有 Nginx/网关，请保持为公网 HTTPS 地址。
CAS_SERVER_NAME=https://sso.beenest.club
CAS_SERVER_PREFIX=https://sso.beenest.club/cas
CAS_SAML_IDP_ENTITY_ID=https://sso.beenest.club/cas/idp
CAS_OIDC_ISSUER=https://sso.beenest.club/cas/oidc

# ---------- Nacos 配置中心 ----------
NACOS_ADDR=10.88.8.11:30002
NACOS_NAMESPACE=prod

# ---------- PostgreSQL ----------
DB_HOST=10.88.8.11
DB_PORT=30001
DB_NAME=beenest
DB_USER=postgres
DB_PASSWORD=123456

# 生产环境保持 validate，数据库结构由 Flyway/初始化脚本管理。
CAS_SERVICE_REGISTRY_JPA_DDL_AUTO=validate
CAS_AUDIT_JDBC_DDL_AUTO=validate
CAS_EVENTS_JPA_DDL_AUTO=validate
CAS_CONSENT_JPA_DDL_AUTO=validate
CAS_AUTHN_MFA_GAUTH_JPA_DDL_AUTO=validate
CAS_AUTHN_MFA_WEBAUTHN_JPA_DDL_AUTO=validate
CAS_AUTHN_MFA_TRUSTED_JPA_DDL_AUTO=validate

# ---------- Redis ----------
REDIS_HOST=10.88.8.11
REDIS_PORT=30003
REDIS_PASSWORD=redis@123
CAS_TICKET_REGISTRY_REDIS_CRYPTO_ENABLED=true

