{
  "@class": "java.util.HashMap",
  "username": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 0,
    "name": "username",
    "type": "text",
    "pattern": ".+",
    "required": true,
    "label": "cas.screen.acct.label.username",
    "title": "cas.screen.acct.title.username"
  },
  "firstName": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 1,
    "name": "firstName",
    "type": "text",
    "pattern": ".+",
    "required": true,
    "label": "cas.screen.acct.label.firstName",
    "title": "cas.screen.acct.title.firstName"
  },
  "lastName": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 2,
    "name": "lastName",
    "type": "text",
    "pattern": ".+",
    "required": true,
    "label": "cas.screen.acct.label.lastName",
    "title": "cas.screen.acct.title.lastName"
  },
  "email": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 3,
    "name": "email",
    "type": "email",
    "pattern": "^\\S+@\\S+\\.\\S+$",
    "required": true,
    "label": "cas.screen.acct.label.email",
    "title": "cas.screen.acct.title.email"
  },
  "phone": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 4,
    "name": "phone",
    "type": "tel",
    "pattern": "^1[3-9]\\d{9}$",
    "required": false,
    "label": "cas.screen.acct.label.phone",
    "title": "cas.screen.acct.title.phone"
  },
  "userType": {
    "@class": "org.apereo.cas.acct.AccountRegistrationProperty",
    "order": 5,
    "name": "userType",
    "type": "select",
    "required": true,
    "values": ["java.util.ArrayList", ["CUSTOMER", "PILOT"]],
    "label": "cas.screen.acct.label.userType",
    "title": "cas.screen.acct.title.userType"
  }
}
