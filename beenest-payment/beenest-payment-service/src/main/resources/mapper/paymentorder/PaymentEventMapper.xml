<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="club.beenest.payment.paymentorder.mapper.PaymentEventMapper">

    <resultMap id="BaseResultMap" type="club.beenest.payment.paymentorder.domain.entity.PaymentEvent">
        <id column="id" property="id" />
        <result column="event_no" property="eventNo" />
        <result column="order_no" property="orderNo" />
        <result column="event_type" property="eventType" />
        <result column="channel" property="channel" />
        <result column="status" property="status" />
        <result column="request_content" property="requestContent" />
        <result column="response_content" property="responseContent" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <insert id="insert" parameterType="club.beenest.payment.paymentorder.domain.entity.PaymentEvent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ds_payment_event (
            event_no, order_no, event_type, channel, status, request_content, response_content, create_time, update_time
        ) VALUES (
            #{eventNo}, #{orderNo}, #{eventType}, #{channel}, #{status}, #{requestContent}, #{responseContent}, NOW(), NOW()
        )
    </insert>

    <update id="update" parameterType="club.beenest.payment.paymentorder.domain.entity.PaymentEvent">
        UPDATE ds_payment_event
        SET
            status = #{status},
            order_no = #{orderNo},
            response_content = #{responseContent},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectByQuery" resultMap="BaseResultMap">
        SELECT * FROM ds_payment_event
        <where>
            <if test="orderNo != null and orderNo != ''">
                AND order_no = #{orderNo}
            </if>
            <if test="eventType != null and eventType != ''">
                AND event_type = #{eventType}
            </if>
            <if test="channel != null and channel != ''">
                AND channel = #{channel}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT * FROM ds_payment_event WHERE id = #{id}
    </select>

</mapper>
