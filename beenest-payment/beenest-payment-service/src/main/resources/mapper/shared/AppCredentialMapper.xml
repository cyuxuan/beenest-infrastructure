<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="club.beenest.payment.shared.mapper.AppCredentialMapper">

    <resultMap id="appCredentialResultMap"
               type="club.beenest.payment.shared.domain.entity.AppCredential">
        <id property="id" column="id"/>
        <result property="appId" column="app_id"/>
        <result property="appName" column="app_name"/>
        <result property="appSecret" column="app_secret"/>
        <result property="mqSecret" column="mq_secret"/>
        <result property="allowedNetworks" column="allowed_networks"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createdBy" column="created_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectAllColumns">
        id, app_id, app_name, app_secret, mq_secret,
        allowed_networks, status, description, created_by, create_time, updated_by, update_time
    </sql>

    <!-- 根据 app_id 查询凭证 -->
    <select id="selectByAppId" resultMap="appCredentialResultMap">
        SELECT <include refid="selectAllColumns"/>
        FROM ds_app_credential
        WHERE app_id = #{appId}
    </select>

    <!-- 查询所有凭证 -->
    <select id="selectAll" resultMap="appCredentialResultMap">
        SELECT <include refid="selectAllColumns"/>
        FROM ds_app_credential
        ORDER BY app_id
    </select>

    <!-- 根据状态查询凭证 -->
    <select id="selectByStatus" resultMap="appCredentialResultMap">
        SELECT <include refid="selectAllColumns"/>
        FROM ds_app_credential
        WHERE status = #{status}
        ORDER BY app_id
    </select>

    <!-- 插入新的应用凭证 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ds_app_credential (
            app_id, app_name, app_secret, mq_secret,
            allowed_networks, status, description, created_by
        ) VALUES (
            #{appId}, #{appName}, #{appSecret}, #{mqSecret},
            #{allowedNetworks}, #{status}, #{description}, #{createdBy}
        )
    </insert>

    <!-- 根据 app_id 更新凭证信息 -->
    <update id="updateByAppId">
        UPDATE ds_app_credential
        <set>
            <if test="appName != null">app_name = #{appName},</if>
            <if test="appSecret != null">app_secret = #{appSecret},</if>
            <if test="mqSecret != null">mq_secret = #{mqSecret},</if>
            <if test="allowedNetworks != null">allowed_networks = #{allowedNetworks},</if>
            <if test="description != null">description = #{description},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        WHERE app_id = #{appId}
    </update>

    <!-- 根据 app_id 更新状态 -->
    <update id="updateStatus">
        UPDATE ds_app_credential
        SET status = #{status},
            update_time = CURRENT_TIMESTAMP
        WHERE app_id = #{appId}
    </update>

</mapper>
